generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEACHER
  PARENT
}

enum InsightStatus {
  NEW
  ACTIONED
  DISMISSED
}

model School {
  id   String @id @default(cuid())
  name String

  users    User[]
  courses  Course[]
  students Student[]
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  role     Role
  language String @default("en")
  schoolId String

  school       School        @relation(fields: [schoolId], references: [id])
  courses      Course[]      @relation("TeacherCourses")
  children     Student[]     @relation("ParentChildren")
  feedbacks    Feedback[]
  chatSessions ChatSession[]
}

model Student {
  id       String @id @default(cuid())
  name     String
  schoolId String
  parentId String

  school           School            @relation(fields: [schoolId], references: [id])
  parent           User              @relation("ParentChildren", fields: [parentId], references: [id])
  enrollments      Enrollment[]
  performanceNotes PerformanceNote[]
}

model Course {
  id            String @id @default(cuid())
  name          String
  yearLevel     String
  subject       String
  syllabusRaw   String @db.Text
  syllabusPlain String @db.Text
  currentWeek   Int
  totalWeeks    Int
  teacherId     String
  schoolId      String

  teacher          User              @relation("TeacherCourses", fields: [teacherId], references: [id])
  school           School            @relation(fields: [schoolId], references: [id])
  enrollments      Enrollment[]
  weeklyFocuses    WeeklyFocus[]
  feedbacks        Feedback[]
  insights         Insight[]
  performanceNotes PerformanceNote[]
}

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  courseId   String

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model PerformanceNote {
  id        String @id @default(cuid())
  label     String
  details   String?
  studentId String
  courseId   String

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model WeeklyFocus {
  id         String @id @default(cuid())
  weekNumber Int
  topic      String
  activity   String @db.Text
  source     String @default("auto") // "auto" | "teacher"
  courseId   String
  createdAt  DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, weekNumber])
}

model Feedback {
  id        String   @id @default(cuid())
  type      String   // "completion" | "difficulty" | "open"
  value     String
  tags      String[] // PostgreSQL text array
  sentiment String?  // "positive" | "neutral" | "negative"
  parentId  String
  courseId   String
  createdAt DateTime @default(now())

  parent User   @relation(fields: [parentId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model Insight {
  id         String        @id @default(cuid())
  dataPoint  String        @db.Text
  therefore  String        @db.Text
  suggestion String        @db.Text
  status     InsightStatus @default(NEW)
  courseId    String
  createdAt  DateTime      @default(now())

  course Course @relation(fields: [courseId], references: [id])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  courseId   String?
  createdAt DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  sessionId String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])
}
