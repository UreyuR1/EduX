# ─── LLM Provider (Required) ──────────────────────────────────────────────────
# Which API provider to use for AI chat features.
# Supported values: "curricullm" | "openai"
#
# "curricullm" (default) — CurricuLLM, an OpenAI-compatible API built for
#    Australian K-12 curriculum. Requires LLM_API_KEY from https://api.curricullm.com
#
# "openai" — Any OpenAI-compatible provider: OpenAI, Together AI, Groq,
#    DeepSeek, Mistral, Ollama (local), etc. Set LLM_BASE_URL to override endpoint.
LLM_PROVIDER=curricullm

# API key for the chosen provider
LLM_API_KEY=your-api-key-here

# Base URL for the LLM API (OpenAI-compatible /v1/chat/completions endpoint)
# CurricuLLM (default):
LLM_BASE_URL=https://api.curricullm.com
# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# Together AI:
# LLM_BASE_URL=https://api.together.xyz/v1
# Groq:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# DeepSeek:
# LLM_BASE_URL=https://api.deepseek.com/v1
# Ollama (local):
# LLM_BASE_URL=http://localhost:11434/v1

# Model name to use
# CurricuLLM (default):
LLM_MODEL=CurricuLLM-AU
# OpenAI examples:
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4o
# Together / open-source examples:
# LLM_MODEL=meta-llama/Llama-3-8b-chat-hf
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# Groq examples:
# LLM_MODEL=llama3-8b-8192
# LLM_MODEL=mixtral-8x7b-32768

# ─── AI Microservice (Optional — not needed for local dev) ────────────────────
# Only needed if running the Python FastAPI service locally
AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ─── Database (Optional — not needed for local dev) ───────────────────────────
# Only needed if running PostgreSQL; mock data is used by default
DATABASE_URL=postgresql://edux:edux_dev@localhost:5432/edux
