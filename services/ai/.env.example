# LLM Provider: "anthropic" (dev) or "curricullm" (production)
LLM_PROVIDER=anthropic

# Anthropic (dev)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20250401

# CurricuLLM (when available)
CURRICULLM_API_KEY=
CURRICULLM_BASE_URL=https://api.curricullm.com

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
