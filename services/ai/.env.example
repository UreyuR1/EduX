# LLM Provider: "anthropic" | "openai" | "curricullm"
# - anthropic  : Anthropic Claude (default, recommended for dev)
# - openai     : OpenAI or any OpenAI-compatible API (Together, Groq, DeepSeek, Mistral, Ollama…)
# - curricullm : CurricuLLM (production placeholder, not yet available)
LLM_PROVIDER=anthropic

# ─── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional: override API base URL (e.g. for a proxy)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ─── OpenAI-compatible (LLM_PROVIDER=openai) ──────────────────────────────────
# Works with OpenAI, Together AI, Groq, DeepSeek, Mistral, Ollama, and more.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Example — Together AI:
#   OPENAI_BASE_URL=https://api.together.xyz/v1
#   OPENAI_MODEL=meta-llama/Llama-3-8b-chat-hf
#
# Example — Groq:
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama3-8b-8192
#
# Example — DeepSeek:
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
#
# Example — Ollama (local):
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3

# ─── CurricuLLM (LLM_PROVIDER=curricullm) ─────────────────────────────────────
CURRICULLM_API_KEY=
CURRICULLM_BASE_URL=https://api.curricullm.com

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
